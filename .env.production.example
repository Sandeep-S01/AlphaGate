APP_ENV=production
HTTP_ADDR=:8080
POSTGRES_DSN=postgres://sentra:replace-with-strong-password@postgres:5432/sentra?sslmode=disable
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0
LOG_LEVEL=info
SHUTDOWN_TIMEOUT=10s

BINANCE_REST_BASE_URL=https://api.binance.com
BINANCE_WS_BASE_URL=wss://stream.binance.com:9443/ws

MARKET_DATA_ENABLED=false
MARKET_DATA_PERSISTENCE_ENABLED=false
MARKET_DATA_SYMBOL=BTCUSDT
MARKET_DATA_INTERVAL=1m
MARKET_DATA_REDIS_STREAM=stream:market-data
MARKET_DATA_CONSUMER_GROUP=market-data-persistence
MARKET_DATA_CONSUMER_NAME=worker-1
MARKET_DATA_MAX_RECONNECTS=100
MARKET_DATA_RECONNECT_DELAY=5s

STRATEGY_ENABLED=false
STRATEGY_NAME=sma-crossover
STRATEGY_VERSION=v1
STRATEGY_SYMBOL=BTCUSDT
STRATEGY_INTERVAL=1m
STRATEGY_FAST_PERIOD=9
STRATEGY_SLOW_PERIOD=21
STRATEGY_LOOKBACK_LIMIT=100
STRATEGY_SIGNAL_STREAM=stream:strategy-signals

RISK_ENABLED=false
RISK_MAX_SIGNAL_STRENGTH=100
RISK_ALLOW_BUY=true
RISK_ALLOW_SELL=true
RISK_SYMBOL=BTCUSDT
RISK_DECISION_STREAM=stream:risk-decisions

EXECUTION_ENABLED=false
EXECUTION_SYMBOL=BTCUSDT
EXECUTION_INTERVAL=1m
EXECUTION_BASE_ASSET=BTC
EXECUTION_QUOTE_ASSET=USDT
EXECUTION_QUOTE_ORDER_AMOUNT=100
EXECUTION_FEE_RATE=0.001
EXECUTION_STREAM=stream:execution-results

ORCHESTRATION_ENABLED=false
ORCHESTRATION_CONSUMER_GROUP=paper-pipeline
ORCHESTRATION_CONSUMER_NAME=worker-1

AUTH_ENABLED=true
ADMIN_API_KEY=replace-with-strong-random-api-key
MAX_REQUEST_BODY_BYTES=1048576
RATE_LIMIT_REQUESTS_PER_MINUTE=120
